# =============================================================================
# Pain Point Research Platform — backend environment
# Copy this file to ".env" in the same folder (backend/) and fill in values.
# =============================================================================

# --- Anthropic Claude (required for /api/research and future /api/build) ---
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model ID (change if your workspace uses a different snapshot)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- SQLite (search history + starred ideas — wired in later steps) ---
# Relative paths resolve from the process working directory (run uvicorn from backend/)
DATABASE_URL=./research.db

# --- CORS: comma-separated origins (production + local Vite dev) ---
CORS_ORIGINS=https://airesearchanalysis.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# --- Optional: public URL of this API (for docs / future webhooks; not required yet) ---
# BACKEND_PUBLIC_URL=https://your-service.up.railway.app

# =============================================================================
# Vercel: if https://your-app.vercel.app/api/... returns 404 in the browser
# =============================================================================
# The Python API only deploys when this Git repo is used as a multi-service
# project (see root vercel.json "experimentalServices").
# In the Vercel project: Settings -> General
#   - Root Directory: leave EMPTY (repository root). Do NOT set it to "frontend".
#   - Framework Preset: choose "Services" (not "Vite" only).
# If Root Directory is "frontend", the build uses frontend/ only: there is no
# experimentalServices there, so "Services" builds fail with "No services configured".
# Docs: https://vercel.com/docs/services
