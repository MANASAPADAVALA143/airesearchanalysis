# =============================================================================
# Pain Point Research Platform — backend environment
# Copy this file to ".env" in the same folder (backend/) and fill in values.
# =============================================================================

# --- Anthropic Claude (required for /api/research and future /api/build) ---
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model ID (change if your workspace uses a different snapshot)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- SQLite (search history + starred ideas — wired in later steps) ---
# Relative paths resolve from the process working directory (run uvicorn from backend/)
DATABASE_URL=./research.db

# --- CORS: comma-separated origins (add your deployed frontend URL when ready) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# --- Optional: public URL of this API (for docs / future webhooks; not required yet) ---
# BACKEND_PUBLIC_URL=https://your-service.up.railway.app
